{{define "title"}}Edit Department | FaithConnect{{end}}
{{define "description"}}Edit ministry department{{end}}

{{define "main"}}
{{$dept    := index .Data "department"}}
{{$members := index .Data "members"}}

<div class="page-wrapper">
    <div class="page-header-bar">
        <div>
            <a href="/departments/{{$dept.ID}}" class="back-link"><i class="fas fa-arrow-left"></i> Back to Department</a>
            <h1 class="page-title-text">Edit Department</h1>
        </div>
    </div>

    {{if .FlashError}}
    <div class="notification is-danger is-light flash-notification mb-4">
        <button class="delete"></button>{{.FlashError}}
    </div>
    {{end}}

    {{$form := .Form}}

    <div class="form-card">
        <form action="/departments/{{$dept.ID}}/edit" method="POST" novalidate>
            <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}">

            <div class="two-col">
                <div class="field-group">
                    <label class="field-label" for="name">Department Name <span class="req">*</span></label>
                    {{with $form.FieldErrors.name}}<p class="field-error">{{.}}</p>{{end}}
                    <input class="field-input {{with $form.FieldErrors.name}}is-danger{{end}}"
                           type="text" id="name" name="name" value="{{$form.Name}}">
                </div>
                <div class="field-group">
                    <label class="field-label" for="department_type">Type <span class="req">*</span></label>
                    {{with $form.FieldErrors.department_type}}<p class="field-error">{{.}}</p>{{end}}
                    <div class="select-wrap">
                        <select class="field-select {{with $form.FieldErrors.department_type}}is-danger{{end}}"
                                id="department_type" name="department_type">
                            {{range deptTypeOptions}}
                            <option value="{{index . 0}}" {{if eq $form.DepartmentType (index . 0)}}selected{{end}}>
                                {{index . 1}}
                            </option>
                            {{end}}
                        </select>
                        <i class="fas fa-chevron-down sel-arrow"></i>
                    </div>
                </div>
            </div>

            <div class="field-group">
                <label class="field-label" for="description">Description</label>
                <textarea class="field-input field-textarea" id="description" name="description"
                          rows="3">{{$form.Description}}</textarea>
            </div>

            <div class="two-col">
                <div class="field-group">
                    <label class="field-label" for="leader_id">Department Leader</label>
                    <div class="select-wrap">
                        <select class="field-select" id="leader_id" name="leader_id">
                            <option value="0">— none —</option>
                            {{range $members}}
                            <option value="{{.ID}}" {{if eq $form.LeaderID .ID}}selected{{end}}>
                                {{.FirstName}} {{.LastName}}
                            </option>
                            {{end}}
                        </select>
                        <i class="fas fa-chevron-down sel-arrow"></i>
                    </div>
                </div>
                <div class="field-group">
                    <label class="field-label">Status</label>
                    <div class="toggle-row">
                        <label class="toggle-switch">
                            <input type="checkbox" name="is_active" value="true"
                                   {{if $form.IsActive}}checked{{end}}>
                            <span class="toggle-track"></span>
                        </label>
                        <span class="toggle-label">Department is active</span>
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <a href="/departments/{{$dept.ID}}" class="button is-light">Cancel</a>
                <button type="submit" class="button is-primary">
                    <span class="icon"><i class="fas fa-save"></i></span>
                    <span>Save Changes</span>
                </button>
            </div>
        </form>
    </div>
</div>

<style>
.page-wrapper { max-width: 680px; margin: 0 auto; padding: 2rem; }
.page-header-bar { margin-bottom: 1.75rem; }
.back-link { display: inline-flex; align-items: center; gap: 6px; font-size: 0.82rem; color: var(--text-light); text-decoration: none; margin-bottom: 4px; }
.back-link:hover { color: var(--primary); }
.page-title-text { font-size: 1.8rem; font-weight: 700; color: var(--text-dark); margin: 0; }
.mb-4 { margin-bottom: 1.5rem; }
.form-card { background: white; border: 1px solid var(--light-gray); border-radius: 16px; padding: 2rem; }
.field-group { margin-bottom: 1.3rem; }
.field-label { display: block; font-size: 0.85rem; font-weight: 600; color: var(--text-dark); margin-bottom: 6px; }
.req { color: #EF4444; }
.field-error { font-size: 0.78rem; color: #EF4444; margin-bottom: 4px; }
.field-input { width: 100%; padding: 10px 13px; border: 1px solid var(--light-gray); border-radius: 9px; font-size: 0.9rem; color: var(--text-dark); background: white; font-family: inherit; box-sizing: border-box; transition: border-color 0.15s; }
.field-input:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(80,34,45,0.1); }
.field-input.is-danger { border-color: #EF4444; }
.field-textarea { resize: vertical; min-height: 80px; }
.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
.select-wrap { position: relative; }
.field-select { appearance: none; width: 100%; padding: 10px 2.2rem 10px 13px; border: 1px solid var(--light-gray); border-radius: 9px; font-size: 0.9rem; color: var(--text-dark); background: white; cursor: pointer; font-family: inherit; }
.field-select:focus { outline: none; border-color: var(--primary); }
.field-select.is-danger { border-color: #EF4444; }
.sel-arrow { position: absolute; right: 12px; top: 50%; transform: translateY(-50%); font-size: 0.65rem; color: var(--text-light); pointer-events: none; }
.toggle-row { display: flex; align-items: center; gap: 12px; }
.toggle-switch { position: relative; flex-shrink: 0; }
.toggle-switch input { opacity: 0; width: 0; height: 0; position: absolute; }
.toggle-track { display: block; width: 42px; height: 24px; border-radius: 12px; background: #D1D5DB; cursor: pointer; transition: background 0.2s; position: relative; }
.toggle-track::after { content: ''; position: absolute; top: 3px; left: 3px; width: 18px; height: 18px; border-radius: 50%; background: white; box-shadow: 0 1px 4px rgba(0,0,0,0.2); transition: transform 0.2s; }
.toggle-switch input:checked + .toggle-track { background: var(--primary); }
.toggle-switch input:checked + .toggle-track::after { transform: translateX(18px); }
.toggle-label { font-size: 0.875rem; color: var(--text-dark); }
.form-actions { display: flex; justify-content: flex-end; gap: 10px; padding-top: 1rem; border-top: 1px solid var(--light-gray); margin-top: 0.5rem; }
@media (max-width: 600px) {
    .page-wrapper { padding: 1rem; }
    .form-card { padding: 1.25rem; }
    .two-col { grid-template-columns: 1fr; }
    .form-actions { flex-direction: column-reverse; }
    .form-actions .button { width: 100%; justify-content: center; }
}
</style>

<script>
document.querySelectorAll('.flash-notification .delete').forEach(b => b.addEventListener('click', () => b.closest('.notification').remove()));
</script>
{{end}}
